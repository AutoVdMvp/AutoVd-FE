{
  "env": {
    "NODE_ENV": "development"
  },
  "permissions": {
    "allow": [
      "Bash(Get-ChildItem -Path \"c:\\\\Users\\\\박요셉\\\\개발모음\\\\autovd-fe\\\\src\" -Recurse -File -Name)",
      "Bash(Sort-Object)",
      "Read(//c/Users/�ڿ��/���߸���/autovd-fe/**)",
      "Bash(Remove-Item \"c:\\\\Users\\\\박요셉\\\\개발모음\\\\autovd-fe\\\\src\\\\widgets\\\\tutorial-modal\\\\ui\\\\steps\\\\TutorialStep1.tsx\", \"c:\\\\Users\\\\박요셉\\\\개발모음\\\\autovd-fe\\\\src\\\\widgets\\\\tutorial-modal\\\\ui\\\\steps\\\\TutorialStep2.tsx\", \"c:\\\\Users\\\\박요셉\\\\개발모음\\\\autovd-fe\\\\src\\\\widgets\\\\tutorial-modal\\\\ui\\\\steps\\\\TutorialStep3.tsx\")"
    ],
    "Write": [
      {
        "allow": true,
        "pattern": "**/*.{ts,tsx,js,jsx,json,md,css,scss}"
      },
      {
        "allow": false,
        "pattern": "node_modules/**"
      },
      {
        "allow": false,
        "pattern": ".next/**"
      },
      {
        "allow": false,
        "pattern": ".git/**"
      }
    ],
    "Edit": [
      {
        "allow": true,
        "pattern": "**/*.{ts,tsx,js,jsx,json,md,css,scss}"
      }
    ],
    "Bash": [
      {
        "allow": true,
        "pattern": "npm|pnpm|yarn"
      },
      {
        "allow": true,
        "pattern": "git"
      },
      {
        "allow": false,
        "pattern": "rm -rf"
      },
      {
        "allow": false,
        "pattern": "sudo"
      }
    ],
    "additionalDirectories": [
      "c:\\Users\\�ڿ��\\���߸���\\autovd-fe\\src\\shared"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write \"$CLAUDE_TOOL_INPUT_FILE_PATH\" 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx eslint --fix \"$CLAUDE_TOOL_INPUT_FILE_PATH\" 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ \"$CLAUDE_TOOL_INPUT_FILE_PATH\" =~ \\.(ts|tsx)$ ]]; then npx tsc --noEmit 2>&1 | head -30 || true; fi"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-dangerous-commands.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/validate-component.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/validate-fsd-imports.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-stop-validation.sh"
          }
        ]
      }
    ]
  }
}
